# Example environment configuration
# Copy this to .env and fill in your actual values
# NEVER commit .env with real secrets!

NEXTREEL_ENV=development
FLASK_ENV=development  # legacy compat — NEXTREEL_ENV takes precedence
FLASK_SECRET_KEY=your-secret-key-here
# Supports either a TMDb v3 API key or a v4 read access token.
TMDB_API_KEY=your-tmdb-api-key-here

# Session Lifetime Configuration
SESSION_IDLE_TIMEOUT_MINUTES=15
MAX_SESSION_DURATION_HOURS=24
COOKIE_DOMAIN=

# Local Redis Configuration
REDIS_URL=redis://localhost:6379
# Optional legacy secret recognized by infra/secrets.py.
REDIS_PASSWORD=

# MySQL Database Configuration for Movies
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=your-db-password-here
DB_NAME=imdb
DB_PORT=3306

# Production Redis (Upstash)
UPSTASH_REDIS_HOST=your-redis-host
UPSTASH_REDIS_PORT=6379
UPSTASH_REDIS_PASSWORD=your-redis-password

# SSL Certificate (Optional)
SSL_CERT_PATH=

# Database Pool Configuration (Advanced)
POOL_MIN_SIZE=5
POOL_MAX_SIZE=20
DB_CONNECT_TIMEOUT=10
DB_POOL_RECYCLE=3600

# Grafana Cloud Configuration (Step 9: Complete Observability)
# Get these from grafana.com → My Account → Cloud Portal
GRAFANA_LOKI_URL=https://logs-prod-xxx.grafana.net
GRAFANA_LOKI_USER=your-loki-user-id
GRAFANA_LOKI_KEY=your-loki-api-key

# Prometheus/Grafana Cloud Metrics (if using remote write)
GRAFANA_PROMETHEUS_URL=https://prometheus-prod-xxx.grafana.net
GRAFANA_PROMETHEUS_USER=your-prometheus-user-id  
GRAFANA_PROMETHEUS_KEY=your-prometheus-api-key

# Ops Endpoint Authentication
# Set this to require a Bearer token on /metrics and /ready endpoints.
# Leave empty to allow unauthenticated access (development only).
OPS_AUTH_TOKEN=

# Application Version (for metrics)
APP_VERSION=1.0.0
